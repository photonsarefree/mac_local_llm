#!/usr/bin/env bash
# llm-check — one-command spot check of the local inference server.
#
#   llm-check                      # sends "Hey, tell me a nerdy joke."
#   llm-check Explain monads briefly.
#   llm-check --temp 0 [prompt]    # greedy instead of the default sampling
#
# Prints the model's reply plus the numbers that tell you the stack is
# healthy: time to first token, decode tokens/sec, and draft acceptance.
set -euo pipefail

PORT="${LLM_SERVE_PORT:-8642}"
TEMP="0.6"
ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        --port) PORT="$2"; shift ;;
        --temp) TEMP="$2"; shift ;;
        -h|--help) sed -n '2,9p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
        *) ARGS+=("$1") ;;
    esac
    shift
done
PROMPT="${ARGS[*]:-Hey, tell me a nerdy joke.}"

BASE="http://127.0.0.1:${PORT}"
if ! curl -s -m 3 "$BASE/v1/models" >/dev/null 2>&1; then
    echo "No server on port $PORT. Start one with: llm-serve 35b" >&2
    exit 1
fi

PY="${RAPID_MLX_VENV:-$HOME/.rapid-mlx}/bin/python"
[ -x "$PY" ] || PY="$(command -v python3)"

BASE="$BASE" PROMPT="$PROMPT" TEMP="$TEMP" "$PY" - <<'PY'
import json, os, time, urllib.request

base, prompt, temp = os.environ["BASE"], os.environ["PROMPT"], float(os.environ["TEMP"])

def metrics():
    try:
        with urllib.request.urlopen(f"{base}/metrics", timeout=5) as r:
            out = {}
            for line in r.read().decode().splitlines():
                if line.startswith("rapid_mlx_spec_decode_a") and " " in line:
                    key, val = line.rsplit(" ", 1)
                    out["accepts" if "accepts_total" in key else
                        "attempts" if "attempts_total" in key else key] = float(val)
            return out
    except Exception:
        return {}

model = "default"
try:
    with urllib.request.urlopen(f"{base}/v1/models", timeout=5) as r:
        model = json.load(r)["data"][0]["id"]
except Exception:
    pass

m0 = metrics()
body = json.dumps({
    "model": "default",
    "messages": [{"role": "user", "content": prompt}],
    "max_tokens": 200,
    "temperature": temp,
    "stream": True,
    "stream_options": {"include_usage": True},
    "chat_template_kwargs": {"enable_thinking": False},
}).encode()
req = urllib.request.Request(f"{base}/v1/chat/completions", data=body,
                             headers={"Content-Type": "application/json"})
t0 = time.perf_counter()
t_first = t_last = None
text, usage = [], {}
with urllib.request.urlopen(req, timeout=300) as r:
    for raw in r:
        raw = raw.strip()
        if not raw.startswith(b"data: ") or raw == b"data: [DONE]":
            continue
        chunk = json.loads(raw[6:])
        if chunk.get("usage"):
            usage = chunk["usage"]
        for c in chunk.get("choices", []):
            piece = c.get("delta", {}).get("content") or ""
            if piece:
                now = time.perf_counter()
                t_first = t_first or now
                t_last = now
                text.append(piece)
m1 = metrics()

reply = "".join(text).strip()
completion = usage.get("completion_tokens")
print(f"\n{reply}\n")
print("─" * 56)
print(f"  model     {model}")
if t_first:
    print(f"  TTFT      {t_first - t0:.2f}s")
if completion and t_last and t_last > t_first:
    rate = (completion - 1) / (t_last - t_first)
    note = "" if completion >= 64 else "  (short sample; rate reads low on tiny replies)"
    print(f"  decode    {rate:.1f} tok/s  ({completion} tokens){note}")
att = (m1.get("attempts", 0) - m0.get("attempts", 0))
acc = (m1.get("accepts", 0) - m0.get("accepts", 0))
if att > 0:
    print(f"  drafting  {acc:.0f}/{att:.0f} drafts accepted ({acc / att:.0%})")
print("─" * 56)
PY
